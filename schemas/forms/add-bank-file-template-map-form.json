{
    "type": "form-container",
    "props": {
        "title": "Add Bank File Template Map",
        "description": "Enter bank file template mapping details",
        "columns": 2,
        "fields": [
            {
                "id": "bankcode",
                "name": "bankcode",
                "label": "Bank Code",
                "type": "select",
                "order": 1,
                "size": "sm",
                "dataSource": {
                    "api": {
                        "endpoint": "/api/moneyout/config/bank-accounts",
                        "method": "GET"
                    }
                },
                "validations": [
                    {
                        "rule": "required",
                        "message": "Bank Code is required"
                    }
                ]
            },
            {
                "id": "payout_mode",
                "name": "payout_mode",
                "label": "Payout Mode",
                "type": "select",
                "order": 2,
                "size": "sm",
                "dataSource": {
                    "api": {
                        "endpoint": "/api/moneyout/config/payout-modes",
                        "method": "GET"
                    }
                },
                "validations": [
                    {
                        "rule": "required",
                        "message": "Payout Mode is required"
                    }
                ]
            },
            {
                "id": "template_id",
                "name": "template_id",
                "label": "Template Id",
                "type": "select",
                "order": 3,
                "size": "sm",
                "dataSource": {
                    "api": {
                        "endpoint": "/api/moneyout/config/payout-templates",
                        "method": "GET"
                    }
                },
                "validations": [
                    {
                        "rule": "required",
                        "message": "Template Id is required"
                    }
                ]
            },
            {
                "id": "effective_date",
                "name": "effective_date",
                "label": "Effective Date",
                "type": "date",
                "order": 4,
                "size": "sm",
                "validations": [
                    {
                        "rule": "required",
                        "message": "Effective Date is required"
                    }
                ]
            },
            {
                "id": "end_date",
                "name": "end_date",
                "label": "End Date",
                "type": "date",
                "order": 5,
                "size": "sm"
            },
            {
                "id": "is_active",
                "name": "is_active",
                "label": "Valid Flag",
                "type": "select",
                "order": 6,
                "size": "sm",
                "options": [
                    { "value": "Y", "label": "Yes" },
                    { "value": "N", "label": "No" }
                ]
            }
        ],
        "actions": [
            {
                "id": "submit-add-bank-file-template-map",
                "label": "Add Mapping",
                "variant": "default",
                "type": "api-mutation",
                "actionType": "action",
                "submitAction": true,
                "refreshKey": "/api/moneyout/config/bank-file-template-map",
                "api": {
                    "endpoint": "/api/moneyout/config/bank-file-template-map",
                    "method": "POST"
                },
                "successMessage": "Bank File Template Map added successfully!"
            },
            {
                "id": "cancel-add-bank-file-template-map",
                "label": "Cancel",
                "variant": "outline",
                "actionType": "action",
                "submitAction": false
            }
        ]
    }
}
