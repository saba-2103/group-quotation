{
    "id": "add-payout-template-form",
    "type": "form-container",
    "props": {
        "title": "Add Payout Template",
        "description": "Enter payout template details",
        "columns": 2,
        "fields": [
            {
                "id": "templateId",
                "name": "templateId",
                "label": "Template Id",
                "type": "text",
                "order": 1,
                "size": "sm",
                "validations": [
                    {
                        "rule": "required",
                        "message": "Template Id is required"
                    }
                ]
            },
            {
                "id": "payoutMode",
                "name": "payoutMode",
                "label": "Payout Mode",
                "type": "select",
                "order": 2,
                "size": "sm",
                "dataSource": {
                    "api": {
                        "endpoint": "/api/moneyout/config/payout-mode-policies",
                        "method": "GET"
                    }
                },
                "validations": [
                    {
                        "rule": "required",
                        "message": "Payout Mode is required"
                    }
                ]
            },
            {
                "id": "outputFilePath",
                "name": "outputFilePath",
                "label": "Output File Path",
                "type": "text",
                "order": 3,
                "size": "sm"
            },
            {
                "id": "outputFormat",
                "name": "outputFormat",
                "label": "Output Format",
                "type": "select",
                "order": 4,
                "size": "sm",
                "options": [
                    { "value": "CSV", "label": "CSV" },
                    { "value": "FIXED", "label": "Fixed Width" }
                ],
                "validations": [
                    {
                        "rule": "required",
                        "message": "Output Format is required"
                    }
                ]
            },
            {
                "id": "outputFileNamePattern",
                "name": "outputFileNamePattern",
                "label": "Output File Name Pattern",
                "type": "text",
                "order": 5,
                "size": "sm",
                "validations": [
                    {
                        "rule": "required",
                        "message": "Output File Name Pattern is required"
                    }
                ]
            },
            {
                "id": "csvDelimiter",
                "name": "csvDelimiter",
                "label": "Delimiter Character (CSV)",
                "type": "text",
                "order": 6,
                "size": "sm"
            },
            {
                "id": "recordSeparator",
                "name": "recordSeparator",
                "label": "Line Feed Character",
                "type": "text",
                "order": 7,
                "size": "sm"
            },
            {
                "id": "enclosureChar",
                "name": "enclosureChar",
                "label": "Quote Character",
                "type": "text",
                "order": 8,
                "size": "sm"
            },
            {
                "id": "headerTemplate",
                "name": "headerTemplate",
                "label": "Optional Header Template",
                "type": "text",
                "order": 9,
                "size": "sm"
            },
            {
                "id": "footerTemplate",
                "name": "footerTemplate",
                "label": "Optional Footer Template",
                "type": "text",
                "order": 10,
                "size": "sm"
            }
        ],
        "actions": [
            {
                "id": "submit-add-payout-template",
                "label": "Add Template",
                "variant": "default",
                "type": "api-mutation",
                "actionType": "action",
                "submitAction": true,
                "refreshKey": "/api/moneyout/config/bank-file-templates",
                "api": {
                    "endpoint": "/api/moneyout/config/bank-file-templates",
                    "method": "POST"
                },
                "successMessage": "Payout Template added successfully!",
                "onSuccess": [
                    { "type": "trigger-event", "target": "add-payout-template-form" }
                ]
            },
            {
                "id": "cancel-add-payout-template",
                "label": "Cancel",
                "variant": "outline",
                "type": "trigger-event",
                "target": "add-payout-template-form",
                "actionType": "action",
                "submitAction": false
            }
        ]
    }
}
