{
  "id": "create-member-quote-form",
  "type": "form-container",
  "props": {
    "title": "New Member Quote (GCL)",
    "description": "Per-member quote against a GCL policy — typically created when the bank disburses a new loan. Cover defaults to the disbursement amount.",
    "columns": 2,
    "fields": [
      {
        "id": "policyId",
        "name": "policyId",
        "label": "Policy",
        "type": "select",
        "order": 1,
        "size": "md",
        "dataSource": {
          "api": {
            "endpoint": "/api/policy-admin/policies/list?page=0&size=200",
            "method": "GET"
          }
        },
        "optionLabel": "policyNumber",
        "optionValue": "id",
        "validations": [{ "rule": "required", "message": "Policy is required" }]
      },
      {
        "id": "name",
        "name": "name",
        "label": "Member name",
        "type": "text",
        "order": 2,
        "size": "md",
        "validations": [{ "rule": "required", "message": "Name is required" }]
      },
      {
        "id": "dob",
        "name": "dob",
        "label": "Date of birth",
        "type": "date",
        "order": 3,
        "size": "md"
      },
      {
        "id": "gender",
        "name": "gender",
        "label": "Gender",
        "type": "select",
        "order": 4,
        "size": "md",
        "options": [
          { "value": "M", "label": "Male" },
          { "value": "F", "label": "Female" },
          { "value": "O", "label": "Other" }
        ]
      },
      {
        "id": "salary",
        "name": "salary",
        "label": "Salary (INR)",
        "type": "number",
        "order": 5,
        "size": "md"
      },
      {
        "id": "occupation",
        "name": "occupation",
        "label": "Occupation",
        "type": "text",
        "order": 6,
        "size": "md"
      },
      {
        "id": "sumAssured",
        "name": "sumAssured",
        "label": "Sum assured (INR) — usually loan disbursement amount",
        "type": "number",
        "order": 7,
        "size": "lg"
      }
    ],
    "actions": [
      {
        "id": "submit-create-member-quote",
        "label": "Create member quote",
        "variant": "default",
        "type": "api-mutation",
        "submitAction": true,
        "refreshKey": "/api/quotation/member-quotes",
        "api": {
          "endpoint": "/api/quotation/member-quotes",
          "method": "POST"
        },
        "successMessage": "Member quote created"
      },
      {
        "id": "cancel-create-member-quote",
        "label": "Cancel",
        "variant": "outline",
        "type": "trigger-event",
        "target": "create-member-quote-form",
        "submitAction": false
      }
    ]
  }
}
