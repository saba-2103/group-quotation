{
    "id": "create-period-form",
    "type": "form-container",
    "props": {
        "title": "Create Accounting Period",
        "fields": [
            {
                "id": "startDate",
                "name": "startDate",
                "label": "Start Date",
                "type": "date",
                "validations": [
                    {
                        "rule": "required",
                        "message": "Start date is required"
                    }
                ]
            },
            {
                "id": "endDate",
                "name": "endDate",
                "label": "End Date",
                "type": "date",
                "validations": [
                    {
                        "rule": "required",
                        "message": "End date is required"
                    }
                ]
            }
        ],
        "actions": [
            {
                "id": "submit-period",
                "type": "api-mutation",
                "label": "Create Period",
                "submitAction": true,
                "variant": "default",
                "refreshKey": "/api/accounting/periods/list?page=0&size=50",
                "api": {
                    "endpoint": "/api/accounting/periods",
                    "method": "POST"
                }
            }
        ]
    }
}