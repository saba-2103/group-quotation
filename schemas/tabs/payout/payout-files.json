{
    "id": "payout-file-formats-tab",
    "type": "tab-panel",
    "props": {
        "value": "payout-files",
        "label": "Payout Files",
        "icon": "FileText"
    },
    "children": [
        {
            "id": "payout-file-formats-table",
            "type": "data-table",
            "dataSource": {
                "api": {
                    "endpoint": "/api/moneyout/config/payout-file-formats",
                    "method": "GET"
                }
            },
            "props": {
                "title": "Payout File Formats",
                "rowIdKey": "id",
                "headerActions": [
                    {
                        "id": "add-payout-file-format-btn",
                        "label": "Add New",
                        "icon": "Plus",
                        "type": "open-modal",
                        "target": "add-payout-file-form",
                        "variant": "outline"
                    }
                ],
                "columns": [
                    {
                        "id": "template_id",
                        "accessorKey": "template_id",
                        "label": "Template Id",
                        "type": "text"
                    },
                    {
                        "id": "seqno",
                        "accessorKey": "seqno",
                        "label": "Seq No.",
                        "type": "text"
                    },
                    {
                        "id": "input_field_name",
                        "accessorKey": "input_field_name",
                        "label": "Input Field Name",
                        "type": "text"
                    },
                    {
                        "id": "output_field_name",
                        "accessorKey": "output_field_name",
                        "label": "Output Field Name",
                        "type": "text"
                    },
                    {
                        "id": "is_mandatory",
                        "accessorKey": "is_mandatory",
                        "label": "Is it Mandatory",
                        "type": "text"
                    }
                ],
                "rowActions": [
                    {
                        "id": "edit-payout-file-format-btn",
                        "label": "Edit",
                        "icon": "Pencil",
                        "type": "open-modal",
                        "target": "edit-payout-file-form"
                    },
                    {
                        "id": "enquire-payout-file-format-btn",
                        "label": "Enquire",
                        "icon": "Eye",
                        "type": "open-modal",
                        "target": "enquire-payout-file-form"
                    },
                    {
                        "id": "delete-payout-file-format-btn",
                        "label": "Delete",
                        "icon": "Trash2",
                        "type": "api-mutation",
                        "variant": "destructive",
                        "confirm": {
                            "title": "Delete Payout File Format",
                            "message": "Are you sure you want to delete this payout file format? This action cannot be undone."
                        },
                        "refreshKey": "/api/moneyout/config/payout-file-formats",
                        "api": {
                            "endpoint": "/api/moneyout/config/payout-file-formats/:seqno",
                            "method": "DELETE"
                        }
                    }
                ]
            }
        }
    ]
}
