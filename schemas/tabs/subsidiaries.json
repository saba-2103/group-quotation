{
    "id": "subsidiaries",
    "type": "tab-panel",
    "props": {
        "label": "Subsidiaries",
        "icon": "Building"
    },
    "children": [
        {
            "id": "subsidiaries-table-section",
            "type": "section-group",
            "props": {
                "title": "Subsidiaries Listing",
                "actions": [
                    {
                        "id": "add-subsidiary",
                        "label": "Add Subsidiary",
                        "icon": "Plus",
                        "variant": "default",
                        "action": {
                            "type": "open-sheet",
                            "target": "add-subsidiary-form"
                        }
                    }
                ]
            },
            "children": [
                {
                    "id": "subsidiaries-table",
                    "type": "data-table",
                    "dataSource": {
                        "type": "api",
                        "api": {
                            "endpoint": "/api/quotations/{{id}}/subsidiaries",
                            "method": "GET"
                        }
                    },
                    "props": {
                        "selectable": true,
                        "columns": [
                            {
                                "id": "subsidiaryCode",
                                "header": "Subsidiary Code",
                                "accessorKey": "subsidiaryCode",
                                "type": "text",
                                "width": "150px"
                            },
                            {
                                "id": "subsidiaryName",
                                "header": "Subsidiary Name",
                                "accessorKey": "subsidiaryName",
                                "type": "text",
                                "width": "200px"
                            },
                            {
                                "id": "locationBranch",
                                "header": "Location/Branch",
                                "accessorKey": "locationBranch",
                                "type": "text",
                                "width": "150px"
                            },
                            {
                                "id": "billingSplitRule",
                                "header": "Billing Split Rule",
                                "accessorKey": "billingSplitRule",
                                "type": "badge",
                                "width": "130px",
                                "valueMapping": [
                                    {
                                        "value": "headcount",
                                        "label": "Headcount",
                                        "color": "default"
                                    },
                                    {
                                        "value": "si",
                                        "label": "Sum Insured",
                                        "color": "info"
                                    },
                                    {
                                        "value": "premium",
                                        "label": "Premium",
                                        "color": "success"
                                    }
                                ]
                            },
                            {
                                "id": "startDate",
                                "header": "Start Date",
                                "accessorKey": "startDate",
                                "type": "date",
                                "width": "120px"
                            },
                            {
                                "id": "endDate",
                                "header": "End Date",
                                "accessorKey": "endDate",
                                "type": "date",
                                "width": "120px"
                            },
                            {
                                "id": "status",
                                "header": "Status",
                                "accessorKey": "status",
                                "type": "badge",
                                "width": "100px",
                                "valueMapping": [
                                    {
                                        "value": "active",
                                        "label": "Active",
                                        "color": "success"
                                    },
                                    {
                                        "value": "terminated",
                                        "label": "Terminated",
                                        "color": "error"
                                    },
                                    {
                                        "value": "lapsed",
                                        "label": "Lapsed",
                                        "color": "warning"
                                    }
                                ]
                            }
                        ],
                        "rowActions": [
                            {
                                "id": "edit",
                                "label": "Edit",
                                "icon": "Pencil",
                                "action": {
                                    "type": "open-sheet",
                                    "target": "edit-subsidiary-form"
                                }
                            },
                            {
                                "id": "lapse",
                                "label": "Lapse",
                                "icon": "Clock",
                                "action": {
                                    "type": "open-modal",
                                    "target": "confirm-lapse"
                                }
                            },
                            {
                                "id": "terminate",
                                "label": "Terminate",
                                "icon": "XCircle",
                                "action": {
                                    "type": "open-modal",
                                    "target": "confirm-terminate"
                                }
                            },
                            {
                                "id": "delete",
                                "label": "Delete",
                                "icon": "Trash2",
                                "action": {
                                    "type": "api",
                                    "target": "delete-subsidiary-api"
                                }
                            }
                        ],
                        "bulkActions": [
                            {
                                "id": "bulk-terminate",
                                "label": "Terminate",
                                "icon": "XCircle",
                                "action": {
                                    "type": "open-modal",
                                    "target": "confirm-bulk-terminate"
                                }
                            },
                            {
                                "id": "bulk-lapse",
                                "label": "Lapse",
                                "icon": "Clock",
                                "action": {
                                    "type": "open-modal",
                                    "target": "confirm-bulk-lapse"
                                }
                            }
                        ],
                        "pagination": {
                            "enabled": true,
                            "pageSize": 10
                        }
                    }
                }
            ]
        }
    ]
}
