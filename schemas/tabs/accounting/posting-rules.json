{
    "id": "posting-rules-tab",
    "type": "tab-panel",
    "props": {
        "value": "posting-rules",
        "label": "Posting Rules",
        "icon": "FileCode2"
    },
    "children": [
        {
            "id": "posting-rules-table",
            "type": "data-table",
            "dataSource": {
                "api": {
                    "endpoint": "/api/accounting/posting-rules/list?page=0&size=50",
                    "method": "GET"
                }
            },
            "props": {
                "title": "Posting Rules",
                "rowIdKey": "ruleId",
                "headerActions": [
                    {
                        "id": "create-posting-rule-btn",
                        "label": "Create Posting Rule",
                        "type": "open-modal",
                        "target": "create-posting-rule-form",
                        "variant": "default"
                    }
                ],
                "columns": [
                    {
                        "id": "ruleId",
                        "accessorKey": "ruleId",
                        "label": "Rule ID",
                        "type": "text"
                    },
                    {
                        "id": "lob",
                        "accessorKey": "lob",
                        "label": "Line of Business",
                        "type": "text"
                    },
                    {
                        "id": "businessProcessCode",
                        "accessorKey": "businessProcessCode",
                        "label": "Business Process Code",
                        "type": "text"
                    },
                    {
                        "id": "accountGroup",
                        "accessorKey": "accountGroup",
                        "label": "Account Group",
                        "type": "text"
                    }
                ],
                "rowActions": [
                    {
                        "id": "view-posting-rule-btn",
                        "label": "View",
                        "icon": "ExternalLink",
                        "type": "navigate",
                        "target": "/accounting/posting-rules/:id"
                    },
                    {
                        "id": "delete-posting-rule-btn",
                        "label": "Delete",
                        "icon": "Trash2",
                        "type": "api-mutation",
                        "variant": "destructive",
                        "api": {
                            "endpoint": "/api/accounting/posting-rules/:ruleId?reason=Deleted+from+UI",
                            "method": "DELETE"
                        },
                        "refreshKey": "/api/accounting/posting-rules/list?page=0&size=50"
                    }
                ]
            }
        }
    ]
}
