{
    "id": "periods-tab",
    "type": "tab-panel",
    "props": {
        "value": "periods",
        "label": "Accounting Periods",
        "icon": "Calendar"
    },
    "children": [
        {
            "id": "periods-table",
            "type": "data-table",
            "dataSource": {
                "api": {
                    "endpoint": "/api/accounting/periods/list?page=0&size=50",
                    "method": "GET"
                }
            },
            "props": {
                "title": "Periods",
                "headerActions": [
                    {
                        "id": "create-period-btn",
                        "label": "Create Period",
                        "type": "open-modal",
                        "target": "create-period-form",
                        "variant": "default"
                    }
                ],
                "columns": [
                    {
                        "id": "accountingYear",
                        "accessorKey": "accountingYear",
                        "label": "Accounting Year",
                        "type": "number"
                    },
                    {
                        "id": "accountingMonth",
                        "accessorKey": "accountingMonth",
                        "label": "Accounting Month",
                        "type": "number"
                    },
                    {
                        "id": "startDate",
                        "accessorKey": "startDate",
                        "label": "Start Date",
                        "type": "date"
                    },
                    {
                        "id": "endDate",
                        "accessorKey": "endDate",
                        "label": "End Date",
                        "type": "date"
                    },
                    {
                        "id": "state",
                        "accessorKey": "state",
                        "label": "Period Status",
                        "type": "badge"
                    },
                    {
                        "id": "isCurrent",
                        "accessorKey": "isCurrent",
                        "label": "Is Current",
                        "type": "text"
                    }
                ]
            }
        }
    ]
}
