{
    "id": "periods-tab",
    "type": "tab-panel",
    "props": {
        "value": "periods",
        "label": "Accounting Periods",
        "icon": "Calendar"
    },
    "children": [
        {
            "id": "periods-table",
            "type": "data-table",
            "dataSource": {
                "api": {
                    "endpoint": "/api/accounting/periods/list?page=0&size=50",
                    "method": "GET"
                }
            },
            "props": {
                "title": "Periods",
                "headerActions": [
                    {
                        "id": "add-period-btn",
                        "label": "Add New Entry",
                        "icon": "Plus",
                        "type": "open-sheet",
                        "target": "create-period-form",
                        "variant": "outline"
                    }
                ],
                "columns": [
                    {
                        "id": "accountingYear",
                        "accessorKey": "accountingYear",
                        "label": "Accounting Year",
                        "type": "number"
                    },
                    {
                        "id": "accountingMonth",
                        "accessorKey": "accountingMonth",
                        "label": "Accounting Month",
                        "type": "number"
                    },
                    {
                        "id": "startDate",
                        "accessorKey": "startDate",
                        "label": "Start Date",
                        "type": "date"
                    },
                    {
                        "id": "endDate",
                        "accessorKey": "endDate",
                        "label": "End Date",
                        "type": "date"
                    },
                    {
                        "id": "state",
                        "accessorKey": "state",
                        "label": "Period Status",
                        "type": "badge"
                    },
                    {
                        "id": "isCurrent",
                        "accessorKey": "isCurrent",
                        "label": "Is Current",
                        "type": "text"
                    }
                ],
                "rowActions": [
                    {
                        "id": "edit-period-btn",
                        "label": "Edit",
                        "icon": "Pencil",
                        "type": "open-modal",
                        "target": "edit-period-form"
                    },
                    {
                        "id": "enquire-period-btn",
                        "label": "Enquire",
                        "icon": "Eye",
                        "type": "open-modal",
                        "target": "enquire-period-form"
                    },
                    {
                        "id": "delete-period-btn",
                        "label": "Delete",
                        "icon": "Trash2",
                        "type": "api-mutation",
                        "variant": "destructive",
                        "confirm": {
                            "title": "Delete Period",
                            "message": "Are you sure you want to delete this accounting period? This action cannot be undone."
                        },
                        "refreshKey": "/api/accounting/periods/list?page=0&size=50",
                        "api": {
                            "endpoint": "/api/accounting/periods/:id",
                            "method": "DELETE"
                        }
                    }
                ]
            }
        }
    ]
}
