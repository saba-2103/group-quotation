{
    "id": "journals-tab",
    "type": "tab-panel",
    "props": {
        "value": "journals",
        "label": "Accounting Journals",
        "icon": "BookOpenText"
    },
    "children": [
        {
            "id": "journals-search-bar",
            "type": "search-bar",
            "props": {
                "stateKey": "accounting:journals:search",
                "filters": [
                    {
                        "id": "component",
                        "label": "Component",
                        "type": "text",
                        "placeholder": "Enter component"
                    },
                    {
                        "id": "business_process_code",
                        "label": "Business Process Code",
                        "type": "text",
                        "placeholder": "Enter business process code"
                    },
                    {
                        "id": "business_key",
                        "label": "Business Key",
                        "type": "text",
                        "placeholder": "Enter business key"
                    }
                ]
            }
        },
        {
            "id": "journals-table",
            "type": "data-table",
            "dataSource": {
                "api": {
                    "endpoint": "/api/accounting/journals/search?page=0&size=50",
                    "method": "GET"
                },
                "fallbackData": [],
                "stateDependencies": ["accounting:journals:search"]
            },
            "props": {
                "title": "Accounting Journals",
                "headerActions": [
                    {
                        "id": "create-journal-btn",
                        "label": "Create Direct Journal",
                        "type": "open-modal",
                        "target": "create-journal-form",
                        "variant": "default"
                    }
                ],
                "columns": [
                    {
                        "id": "journal_number",
                        "accessorKey": "journal_number",
                        "label": "Journal Number",
                        "type": "text"
                    },
                    {
                        "id": "journal_date",
                        "accessorKey": "journal_date",
                        "label": "Journal Date",
                        "type": "date"
                    },
                    {
                        "id": "account_year",
                        "accessorKey": "account_year",
                        "label": "Accounting Year",
                        "type": "text"
                    },
                    {
                        "id": "account_month",
                        "accessorKey": "account_month",
                        "label": "Accounting Month",
                        "type": "text"
                    },
                    {
                        "id": "journal_status",
                        "accessorKey": "journal_status",
                        "label": "Journal Status",
                        "type": "badge"
                    },
                    {
                        "id": "reversed_journal_number",
                        "accessorKey": "reversed_journal_number",
                        "label": "Reversed Journal Number",
                        "type": "text"
                    },
                    {
                        "id": "balance_error_flag",
                        "accessorKey": "balance_error_flag",
                        "label": "Balance Error (Y/N)",
                        "type": "text"
                    },
                    {
                        "id": "component",
                        "accessorKey": "component",
                        "label": "Component Id",
                        "type": "text"
                    },
                    {
                        "id": "lob",
                        "accessorKey": "lob",
                        "label": "Line of Business",
                        "type": "text"
                    },
                    {
                        "id": "business_key",
                        "accessorKey": "business_key",
                        "label": "Business Key",
                        "type": "text"
                    },
                    {
                        "id": "tranno",
                        "accessorKey": "tranno",
                        "label": "Transaction Number",
                        "type": "number"
                    },
                    {
                        "id": "business_process_code",
                        "accessorKey": "business_process_code",
                        "label": "Business Process Code",
                        "type": "text"
                    },
                    {
                        "id": "accounting_event_id",
                        "accessorKey": "accounting_event_id",
                        "label": "Accounting Event Id",
                        "type": "text"
                    },
                    {
                        "id": "account_group",
                        "accessorKey": "account_group",
                        "label": "Account Group",
                        "type": "text"
                    }
                ],
                "rowActions": [
                    {
                        "id": "view-journal-btn",
                        "label": "View",
                        "icon": "ExternalLink",
                        "type": "navigate",
                        "target": "/accounting/journal/:id"
                    },
                    {
                        "id": "post-journal-btn",
                        "label": "Post Journal",
                        "type": "api-mutation",
                        "visible": {
                            "==": [
                                {
                                    "var": "journal_status"
                                },
                                "PENDING"
                            ]
                        },
                        "api": {
                            "endpoint": "/api/accounting/journals/:journal_number/post",
                            "method": "POST"
                        },
                        "refreshKey": "/api/accounting/journals/search?page=0&size=50"
                    },
                    {
                        "id": "reverse-journal-btn",
                        "label": "Reverse",
                        "type": "open-modal",
                        "target": "reverse-journal-form",
                        "visible": {
                            "==": [
                                {
                                    "var": "journal_status"
                                },
                                "POSTED"
                            ]
                        }
                    }
                ]
            }
        }
    ]
}
