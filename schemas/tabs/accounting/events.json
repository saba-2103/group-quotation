{
    "id": "events-tab",
    "type": "tab-panel",
    "props": {
        "value": "events",
        "label": "Accounting Events",
        "icon": "Activity"
    },
    "children": [
        {
            "id": "events-table",
            "type": "data-table",
            "dataSource": {
                "api": {
                    "endpoint": "/api/accounting/events/list?page=0&size=50",
                    "method": "GET"
                }
            },
            "props": {
                "title": "Accounting Events",
                "headerActions": [
                    {
                        "id": "create-event-btn",
                        "label": "Create Event",
                        "type": "open-modal",
                        "target": "create-event-form",
                        "variant": "default"
                    }
                ],
                "columns": [
                    {
                        "id": "component",
                        "accessorKey": "component",
                        "label": "Component",
                        "type": "text"
                    },
                    {
                        "id": "lob",
                        "accessorKey": "lob",
                        "label": "Line of Business",
                        "type": "text"
                    },
                    {
                        "id": "businessKey",
                        "accessorKey": "businessKey",
                        "label": "Business Key",
                        "type": "text"
                    },
                    {
                        "id": "tranno",
                        "accessorKey": "tranno",
                        "label": "Transaction Number",
                        "type": "number"
                    },
                    {
                        "id": "businessProcessCode",
                        "accessorKey": "businessProcessCode",
                        "label": "Business Process Code",
                        "type": "text"
                    },
                    {
                        "id": "businessProcessDescription",
                        "accessorKey": "businessProcessDescription",
                        "label": "Business Process Description",
                        "type": "text"
                    },
                    {
                        "id": "accountingEventId",
                        "accessorKey": "accountingEventId",
                        "label": "Accounting Event Id",
                        "type": "text"
                    },
                    {
                        "id": "eventDate",
                        "accessorKey": "eventDate",
                        "label": "Event Date",
                        "type": "date"
                    },
                    {
                        "id": "reversalFlag",
                        "accessorKey": "reversalFlag",
                        "label": "Reversal Flag",
                        "type": "text"
                    },
                    {
                        "id": "eventStatus",
                        "accessorKey": "eventStatus",
                        "label": "Event Status",
                        "type": "badge"
                    },
                    {
                        "id": "eventStatusDate",
                        "accessorKey": "eventStatusDate",
                        "label": "Event Status Date",
                        "type": "date"
                    }
                ],
                "rowActions": [
                    {
                        "id": "post-event-btn",
                        "label": "Post Event",
                        "type": "api-mutation",
                        "visible": {
                            "==": [
                                {
                                    "var": "eventStatus"
                                },
                                "PENDING"
                            ]
                        },
                        "refreshKey": "/api/accounting/events/list?page=0&size=50",
                        "api": {
                            "endpoint": "/api/accounting/events/:id/post",
                            "method": "POST"
                        }
                    },
                    {
                        "id": "reverse-event-btn",
                        "label": "Reverse",
                        "type": "open-modal",
                        "target": "reverse-event-form",
                        "visible": {
                            "==": [
                                {
                                    "var": "eventStatus"
                                },
                                "POSTED"
                            ]
                        }
                    }
                ]
            }
        }
    ]
}