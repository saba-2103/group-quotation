{
  "id": "proposal-members-tab",
  "type": "tab-panel",
  "props": { "value": "members", "label": "Members", "icon": "Users" },
  "children": [
    {
      "id": "proposal-members-filters",
      "type": "filter-bar",
      "props": {
        "stateKey": "proposal-members-filters",
        "filters": [
          {
            "id": "state",
            "label": "State",
            "type": "select",
            "options": [
              { "value": "CREATED", "label": "Created" },
              { "value": "PRICED", "label": "Priced" },
              { "value": "MAF_PENDING", "label": "MAF pending" },
              { "value": "MAF_CONFIRMED", "label": "MAF confirmed" },
              { "value": "CLASSIFYING", "label": "Classifying" },
              { "value": "REPAIR_PENDING", "label": "Repair queue" },
              { "value": "REFERRED_TO_UW", "label": "UW review" },
              { "value": "APPROVED", "label": "Approved" },
              { "value": "SENT_FOR_ISSUANCE", "label": "Sent for issuance" },
              { "value": "ADDED", "label": "Added" },
              { "value": "REJECTED", "label": "Rejected" },
              { "value": "ARCHIVED", "label": "Archived" }
            ]
          }
        ]
      }
    },
    {
      "id": "proposal-members-table",
      "type": "data-table",
      "dataSource": {
        "api": {
          "endpoint": "/api/issuance/proposals/{{id}}/members",
          "method": "GET"
        },
        "stateDependencies": ["proposal-members-filters"]
      },
      "props": {
        "title": "Policy members in this proposal",
        "headerActions": [
          {
            "id": "add-member-btn",
            "label": "Add member",
            "icon": "UserPlus",
            "type": "navigate",
            "target": "/issuance/proposals/{{id}}/members/new",
            "variant": "default"
          }
        ],
        "columns": [
          {
            "id": "id",
            "accessorKey": "id",
            "label": "PolicyMember ID",
            "type": "link",
            "linkRoute": "/issuance/proposals/{{id}}/members/:id"
          },
          { "id": "name", "accessorKey": "name", "label": "Name", "type": "text" },
          { "id": "planNo", "accessorKey": "planNo", "label": "Plan", "type": "text" },
          { "id": "state", "accessorKey": "state", "label": "State", "type": "state-badge", "entity": "policyMember" },
          { "id": "premium", "accessorKey": "annualPremiumAmount", "label": "Annual premium", "type": "currency", "currency": "INR" }
        ],
        "rowActions": [
          {
            "id": "view-pm-btn",
            "label": "View",
            "icon": "Eye",
            "type": "navigate",
            "target": "/issuance/proposals/{{id}}/members/:id"
          }
        ],
        "emptyState": {
          "title": "No members in this proposal yet",
          "description": "Add a single member or bulk-upload a census file to populate this list. Filters above narrow by state."
        }
      }
    }
  ]
}
