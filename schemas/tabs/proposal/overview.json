{
  "id": "proposal-overview-tab",
  "type": "tab-panel",
  "props": { "value": "overview", "label": "Overview", "icon": "Info" },
  "children": [
    {
      "id": "proposal-overview-grid",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/issuance/proposals/{{id}}", "method": "GET" }
      },
      "props": {
        "title": "Proposal — read-only data carried from the source quote (W2 step 1)",
        "columns": 3,
        "fields": [
          { "id": "id", "label": "Proposal ID", "accessorKey": "id" },
          { "id": "quoteId", "label": "Source quote", "accessorKey": "quoteId" },
          { "id": "clientId", "label": "Client", "accessorKey": "clientId" },
          { "id": "policyType", "label": "Policy type", "accessorKey": "policyType" },
          { "id": "memberToPlanMapping", "label": "Member-to-Plan DMN", "accessorKey": "memberToPlanMapping", "type": "presence" },
          { "id": "policyNumber", "label": "Created policy #", "accessorKey": "policyNumber" }
        ]
      }
    }
  ]
}
