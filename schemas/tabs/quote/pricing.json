{
  "id": "quote-pricing-tab",
  "type": "tab-panel",
  "props": { "value": "pricing", "label": "Pricing", "icon": "Calculator" },
  "children": [
    {
      "id": "quote-pricing-grid",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" },
        "pollSchedule": {
          "initialIntervalMs": 2000,
          "initialDurationMs": 10000,
          "fallbackIntervalMs": 5000,
          "maxDurationMs": 60000
        },
        "stopWhen": { "!=": [{ "var": "estimatedPremium.totalAmount" }, 0] }
      },
      "props": {
        "title": "Pricing",
        "description": "Click \"Request price\" to kick off the Rule Engine. The page polls (2s for 10s, then 5s up to 60s) and stops once the premium lands.",
        "columns": 2,
        "fields": [
          { "id": "premiumTotal", "label": "Annual premium (total)", "accessorKey": "estimatedPremium.totalAmount" },
          { "id": "premiumCurrency", "label": "Currency", "accessorKey": "estimatedPremium.currency" }
        ]
      }
    },
    {
      "id": "quote-pricing-actions",
      "type": "action-bar",
      "props": {
        "state": "DRAFT",
        "stateActions": { "DRAFT": ["request-price"] },
        "roleActions": { "maker": ["request-price"], "checker": [], "ops": [], "viewer": [] },
        "entityType": "quote",
        "entityId": "{{id}}",
        "actions": [
          {
            "id": "request-price",
            "label": "Request price",
            "icon": "Calculator",
            "type": "api-mutation",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": {
              "endpoint": "/api/quotation/quotes/{{id}}/request-price",
              "method": "POST"
            },
            "successMessage": "Pricing request submitted; polling for premium..."
          }
        ]
      }
    }
  ]
}
