{
  "id": "quote-pricing-tab",
  "type": "tab-panel",
  "props": { "value": "pricing", "label": "Pricing", "icon": "Calculator" },
  "children": [
    {
      "id": "quote-pricing-grid",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "title": "Pricing",
        "description": "Premium is computed by the Rule Engine on Quote.requestPrice. The pricing engine is not yet wired on the backend, so requests fire-and-forget and the premium does not populate. The fields below stay zero until backend ships the engine.",
        "columns": 2,
        "fields": [
          { "id": "premiumTotal", "label": "Annual premium (total)", "accessorKey": "estimatedPremium.totalAmount" },
          { "id": "premiumCurrency", "label": "Currency", "accessorKey": "estimatedPremium.currency" }
        ]
      }
    },
    {
      "id": "quote-pricing-actions",
      "type": "action-bar",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "stateField": "status",
        "stateActions": { "DRAFT": ["request-price"] },
        "roleActions": { "maker": ["request-price"], "checker": [], "ops": [], "viewer": [] },
        "actions": [
          {
            "id": "request-price",
            "label": "Request price",
            "icon": "Calculator",
            "type": "api-mutation",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": {
              "endpoint": "/api/quotation/quotes/{{id}}/request-price",
              "method": "POST"
            },
            "disabledTooltip": "Pricing engine not yet wired on backend — request fires-and-forgets to no listener. Button enabled once Rule Engine ships."
          }
        ]
      }
    }
  ]
}
