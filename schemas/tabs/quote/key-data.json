{
  "id": "quote-key-data-tab",
  "type": "tab-panel",
  "props": { "value": "key-data", "label": "Key Data", "icon": "Settings" },
  "children": [
    {
      "id": "quote-key-data-grid",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "title": "Quote details",
        "description": "Read-only for V1. Maker-only edit lands in D-edit.",
        "columns": 3,
        "fields": [
          { "id": "id", "label": "Quote ID", "accessorKey": "id" },
          { "id": "clientId", "label": "Client", "accessorKey": "clientId" },
          { "id": "policyType", "label": "Policy type", "accessorKey": "policyType" },
          { "id": "premiumType", "label": "Premium type", "accessorKey": "premiumType" },
          { "id": "lineOfBusiness", "label": "Line of business", "accessorKey": "lineOfBusiness" },
          { "id": "riskTermClassification", "label": "Risk term classification", "accessorKey": "riskTermClassification" },
          { "id": "ageDefinitionRule", "label": "Age definition rule", "accessorKey": "ageDefinitionRule" },
          { "id": "effectiveDate", "label": "Effective date", "accessorKey": "effectiveDate", "type": "date" },
          { "id": "expiryDate", "label": "Expiry date", "accessorKey": "expiryDate", "type": "date" },
          { "id": "inceptionDate", "label": "Inception date", "accessorKey": "inceptionDate", "type": "date" }
        ]
      }
    }
  ]
}
