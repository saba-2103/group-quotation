{
  "id": "quote-member-mapping-tab",
  "type": "tab-panel",
  "props": { "value": "member-mapping", "label": "Member-to-Plan Mapping", "icon": "GitBranch" },
  "children": [
    {
      "id": "quote-member-mapping-table",
      "type": "dmn-decision-table",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "title": "Member-to-Plan mapping",
        "description": "DMN decision table that routes each member to a plan. Read-only here; replace the whole blob via the action below. DMN authoring UI is out of V1 scope (spec §5).",
        "mappingPath": "memberToPlanMappingJson"
      }
    },
    {
      "id": "quote-member-mapping-actions",
      "type": "action-bar",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "stateField": "status",
        "stateActions": { "DRAFT": ["replace-mapping"] },
        "roleActions": {
          "maker": [],
          "checker": ["replace-mapping"],
          "ops": [],
          "viewer": []
        },
        "actions": [
          {
            "id": "replace-mapping",
            "label": "Replace mapping",
            "icon": "Replace",
            "type": "open-modal",
            "target": "member-mapping-replace-form",
            "variant": "outline"
          }
        ]
      }
    }
  ]
}
