{
  "id": "quote-member-mapping-tab",
  "type": "tab-panel",
  "props": { "value": "member-mapping", "label": "Member-to-Plan Mapping", "icon": "GitBranch" },
  "children": [
    {
      "id": "quote-member-mapping-grid",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "title": "Member-to-Plan mapping",
        "description": "Read-only for V1 demo. DMN authoring out of scope; replace flow deferred to D3. The mapping below is the parsed DMN ref.",
        "columns": 2,
        "fields": [
          {
            "id": "mappingPolicy",
            "label": "Hit policy",
            "accessorKey": "memberToPlanMappingJson",
            "parseJson": true,
            "subPath": "hits"
          },
          {
            "id": "ruleCount",
            "label": "Rules",
            "accessorKey": "memberToPlanMappingJson",
            "parseJson": true,
            "subPath": "rules",
            "type": "count",
            "unit": "rule",
            "unitPlural": "rules"
          },
          {
            "id": "ruleConditions",
            "label": "Conditions",
            "accessorKey": "memberToPlanMappingJson",
            "parseJson": true,
            "subPath": "rules",
            "type": "list",
            "itemPath": "if"
          },
          {
            "id": "ruleTargets",
            "label": "Target plans",
            "accessorKey": "memberToPlanMappingJson",
            "parseJson": true,
            "subPath": "rules",
            "type": "list",
            "itemPath": "then"
          }
        ]
      }
    }
  ]
}
