{
  "id": "quote-plans-tab",
  "type": "tab-panel",
  "props": { "value": "plans", "label": "Plans", "icon": "Layers" },
  "children": [
    {
      "id": "quote-plans-info",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "title": "Plan structure",
        "description": "Read-only for V1 demo. Add / edit / remove deferred to D1; the demo renders the plans configured on the fixture.",
        "columns": 2,
        "fields": [
          {
            "id": "plansCount",
            "label": "Plans configured",
            "accessorKey": "plans",
            "type": "count",
            "unit": "plan",
            "unitPlural": "plans"
          },
          {
            "id": "planNumbers",
            "label": "Plan numbers",
            "accessorKey": "plans",
            "type": "list",
            "itemPath": "planNo"
          },
          {
            "id": "planNames",
            "label": "Plan names",
            "accessorKey": "plans",
            "type": "list",
            "itemPath": "planName"
          },
          {
            "id": "rateCardFiles",
            "label": "Rate-card files",
            "accessorKey": "plans",
            "type": "list",
            "itemPath": "rateCardFile"
          },
          {
            "id": "headcount",
            "label": "Census headcount",
            "accessorKey": "headcount"
          },
          {
            "id": "firstPlanCoverFormula",
            "label": "Cover formula (first plan)",
            "accessorKey": "plans.0.coverAmountFormulaJson",
            "parseJson": true,
            "subPath": "type"
          }
        ]
      }
    }
  ]
}
