{
    "id": "members",
    "type": "tab-panel",
    "props": {
        "label": "Members",
        "icon": "Users"
    },
    "children": [
        {
            "id": "members-stack",
            "type": "stack-layout",
            "props": {
                "spacing": "6"
            },
            "children": [
                {
                    "id": "member-filter",
                    "type": "filter-bar",
                    "props": {
                        "placeholder": "Search members...",
                        "filters": [
                            {
                                "id": "fclStatus",
                                "label": "FCL Status",
                                "type": "select",
                                "options": [
                                    {
                                        "value": "within",
                                        "label": "Within"
                                    },
                                    {
                                        "value": "above",
                                        "label": "Above"
                                    }
                                ]
                            },
                            {
                                "id": "pricingStatus",
                                "label": "Pricing Status",
                                "type": "select",
                                "options": [
                                    {
                                        "value": "rated",
                                        "label": "Rated"
                                    },
                                    {
                                        "value": "unrated",
                                        "label": "Unrated"
                                    }
                                ]
                            }
                        ]
                    }
                },
                {
                    "id": "member-actions-section",
                    "type": "section-group",
                    "props": {
                        "title": "Single Member Operations"
                    },
                    "children": [
                        {
                            "id": "member-actions",
                            "type": "quick-links-widget",
                            "props": {
                                "layout": "inline",
                                "links": [
                                    {
                                        "id": "cancel",
                                        "label": "Cancel from Inception",
                                        "icon": "XCircle",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "cancel-member-form"
                                        }
                                    },
                                    {
                                        "id": "surrender",
                                        "label": "Surrender",
                                        "icon": "HandCoins",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "surrender-member-form"
                                        }
                                    },
                                    {
                                        "id": "pre-existing",
                                        "label": "Pre-existing Conditions",
                                        "icon": "HeartPulse",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "pre-existing-conditions-form"
                                        }
                                    },
                                    {
                                        "id": "exclusions",
                                        "label": "Member Exclusions",
                                        "icon": "ShieldOff",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "member-exclusions-form"
                                        }
                                    },
                                    {
                                        "id": "add-dependent",
                                        "label": "Add Dependent",
                                        "icon": "UserPlus",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "add-dependent-form"
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "id": "members-table-section",
                    "type": "section-group",
                    "props": {
                        "title": "Member Listing",
                        "actions": [
                            {
                                "id": "upload-members",
                                "label": "Member Upload",
                                "icon": "Upload",
                                "variant": "default",
                                "action": {
                                    "type": "open-sheet",
                                    "target": "upload-members-form"
                                }
                            },
                            {
                                "id": "export-roster",
                                "label": "Export Roster",
                                "icon": "Download",
                                "variant": "outline",
                                "action": {
                                    "type": "api",
                                    "target": "/api/policy/members/export"
                                }
                            }
                        ]
                    },
                    "children": [
                        {
                            "id": "members-table",
                            "type": "data-table",
                            "dataSource": {
                                "type": "api",
                                "api": {
                                    "endpoint": "/api/quotations/{{id}}/members",
                                    "method": "GET"
                                }
                            },
                            "props": {
                                "columns": [
                                    {
                                        "id": "memberNumber",
                                        "header": "Member Number",
                                        "accessorKey": "id",
                                        "type": "text",
                                        "width": "120px"
                                    },
                                    {
                                        "id": "memberName",
                                        "header": "Member Name",
                                        "accessorKey": "memberName",
                                        "type": "link",
                                        "linkRoute": "/members/:id/master",
                                        "width": "150px"
                                    },
                                    {
                                        "id": "planNumber",
                                        "header": "Plan No.",
                                        "accessorKey": "planNumber",
                                        "type": "text",
                                        "width": "100px"
                                    },
                                    {
                                        "id": "currentCoverageSI",
                                        "header": "Coverage SI",
                                        "accessorKey": "currentCoverageSI",
                                        "type": "currency",
                                        "width": "130px",
                                        "align": "right"
                                    },
                                    {
                                        "id": "fclStatus",
                                        "header": "FCL Status",
                                        "accessorKey": "fclStatus",
                                        "type": "badge",
                                        "width": "110px",
                                        "valueMapping": [
                                            {
                                                "value": "within",
                                                "label": "Within",
                                                "color": "success"
                                            },
                                            {
                                                "value": "above",
                                                "label": "Above",
                                                "color": "error"
                                            },
                                            {
                                                "value": "not-computed",
                                                "label": "N/A",
                                                "color": "default"
                                            }
                                        ]
                                    },
                                    {
                                        "id": "excessSI",
                                        "header": "Excess SI",
                                        "accessorKey": "excessSI",
                                        "type": "currency",
                                        "width": "120px",
                                        "align": "right"
                                    },
                                    {
                                        "id": "pricingStatus",
                                        "header": "Pricing Status",
                                        "accessorKey": "pricingStatus",
                                        "type": "badge",
                                        "width": "130px",
                                        "valueMapping": [
                                            {
                                                "value": "rated",
                                                "label": "Rated",
                                                "color": "success"
                                            },
                                            {
                                                "value": "unrated",
                                                "label": "Unrated",
                                                "color": "error"
                                            },
                                            {
                                                "value": "override-pending",
                                                "label": "Override Pending",
                                                "color": "warning"
                                            }
                                        ]
                                    },
                                    {
                                        "id": "premium",
                                        "header": "Premium",
                                        "accessorKey": "premium",
                                        "type": "currency",
                                        "width": "120px",
                                        "align": "right"
                                    }
                                ],
                                "rowActions": [
                                    {
                                        "id": "edit",
                                        "label": "Edit",
                                        "icon": "Pencil",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "edit-member-form"
                                        }
                                    },
                                    {
                                        "id": "delete",
                                        "label": "Delete",
                                        "icon": "Trash2",
                                        "variant": "destructive",
                                        "action": {
                                            "type": "api",
                                            "target": "delete-member-api"
                                        }
                                    }
                                ],
                                "bulkActions": [
                                    {
                                        "id": "bulk-verify",
                                        "label": "Verify Selected",
                                        "icon": "CircleCheck",
                                        "variant": "outline",
                                        "action": {
                                            "type": "open-modal",
                                            "target": "bulk-verify-form"
                                        }
                                    },
                                    {
                                        "id": "bulk-download",
                                        "label": "Download Selected",
                                        "icon": "Download",
                                        "variant": "outline",
                                        "action": {
                                            "type": "api",
                                            "target": "bulk-download-api"
                                        }
                                    }
                                ],
                                "pagination": {
                                    "enabled": true,
                                    "pageSize": 10
                                },
                                "selectable": true
                            }
                        }
                    ]
                }
            ]
        }
    ]
}
