{
    "id": "documents",
    "type": "tab-panel",
    "props": {
        "label": "Documents",
        "icon": "FileText"
    },
    "children": [
        {
            "id": "documents-stack",
            "type": "stack-layout",
            "props": {
                "spacing": "6"
            },
            "children": [
                {
                    "id": "docs-progress",
                    "type": "section-group",
                    "props": {
                        "title": "Document Requirements & Progress"
                    },
                    "children": [
                        {
                            "id": "docs-progress-links",
                            "type": "quick-links-widget",
                            "props": {
                                "layout": "grid",
                                "links": [
                                    {
                                        "id": "req-docs",
                                        "label": "Required Documents",
                                        "type": "card",
                                        "icon": "FileText",
                                        "description": "8 documents based on scheme type & UW method"
                                    },
                                    {
                                        "id": "submitted-docs",
                                        "label": "Submitted",
                                        "type": "card",
                                        "icon": "Upload",
                                        "description": "5 documents uploaded"
                                    },
                                    {
                                        "id": "missing-docs",
                                        "label": "Missing",
                                        "type": "card",
                                        "icon": "CircleAlert",
                                        "description": "3 documents - Requires immediate attention"
                                    },
                                    {
                                        "id": "verified-docs",
                                        "label": "Verified",
                                        "type": "card",
                                        "icon": "CircleCheck",
                                        "description": "3 documents approved for UW"
                                    },
                                    {
                                        "id": "expired-docs",
                                        "label": "Expired",
                                        "type": "card",
                                        "icon": "Clock",
                                        "description": "1 document needs resubmission"
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "id": "docs-alerts",
                    "type": "section-group",
                    "props": {
                        "title": "Document Intelligence & Blockers"
                    },
                    "children": [
                        {
                            "id": "docs-alerts-links",
                            "type": "quick-links-widget",
                            "props": {
                                "layout": "grid",
                                "links": [
                                    {
                                        "id": "alert-medical",
                                        "label": "BLOCKER: Medical Data Missing",
                                        "type": "card",
                                        "icon": "ShieldAlert",
                                        "description": "Medical examination reports required for members above 45 years.",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "request-document-form"
                                        }
                                    },
                                    {
                                        "id": "alert-kyc",
                                        "label": "KYC Documents Expired",
                                        "type": "card",
                                        "icon": "TriangleAlert",
                                        "description": "KYC documents expired on 2025-01-01.",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "request-document-form"
                                        }
                                    },
                                    {
                                        "id": "alert-fin",
                                        "label": "Financial Details Pending Verification",
                                        "type": "card",
                                        "icon": "Clock",
                                        "description": "Financial statements uploaded but awaiting underwriter verification.",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "verify-document-form"
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "id": "docs-table-section",
                    "type": "section-group",
                    "props": {
                        "title": "Document Registry",
                        "actions": [
                            {
                                "id": "add-doc",
                                "label": "Add Document",
                                "icon": "Plus",
                                "variant": "default",
                                "action": {
                                    "type": "open-sheet",
                                    "target": "add-document-form"
                                }
                            }
                        ]
                    },
                    "children": [
                        {
                            "id": "documents-table",
                            "type": "data-table",
                            "dataSource": {
                                "type": "api",
                                "api": {
                                    "endpoint": "/api/quotations/{{id}}/documents",
                                    "method": "GET"
                                }
                            },
                            "props": {
                                "columns": [
                                    {
                                        "id": "docType",
                                        "header": "Document Type",
                                        "accessorKey": "documentType",
                                        "type": "text",
                                        "width": "200px"
                                    },
                                    {
                                        "id": "docSource",
                                        "header": "Source",
                                        "accessorKey": "documentSource",
                                        "type": "badge",
                                        "width": "120px",
                                        "valueMapping": [
                                            {
                                                "value": "client",
                                                "label": "Client",
                                                "color": "default"
                                            },
                                            {
                                                "value": "broker",
                                                "label": "Broker",
                                                "color": "info"
                                            },
                                            {
                                                "value": "lender",
                                                "label": "Lender",
                                                "color": "warning"
                                            },
                                            {
                                                "value": "insurer",
                                                "label": "Insurer",
                                                "color": "success"
                                            }
                                        ]
                                    },
                                    {
                                        "id": "linkedEntity",
                                        "header": "Linked To",
                                        "accessorKey": "linkedEntity",
                                        "type": "text",
                                        "width": "180px"
                                    },
                                    {
                                        "id": "effDate",
                                        "header": "Effective Date",
                                        "accessorKey": "effectiveDate",
                                        "type": "date",
                                        "width": "140px"
                                    },
                                    {
                                        "id": "expDate",
                                        "header": "Expiry Date",
                                        "accessorKey": "expiryDate",
                                        "type": "date",
                                        "width": "140px"
                                    },
                                    {
                                        "id": "uploadedBy",
                                        "header": "Uploaded By",
                                        "accessorKey": "uploadedBy",
                                        "type": "text",
                                        "width": "150px"
                                    },
                                    {
                                        "id": "verStatus",
                                        "header": "Verification",
                                        "accessorKey": "verificationStatus",
                                        "type": "status",
                                        "width": "140px",
                                        "valueMapping": [
                                            {
                                                "value": "pending",
                                                "label": "Pending",
                                                "color": "warning"
                                            },
                                            {
                                                "value": "verified",
                                                "label": "Verified",
                                                "color": "success"
                                            },
                                            {
                                                "value": "rejected",
                                                "label": "Rejected",
                                                "color": "error"
                                            },
                                            {
                                                "value": "expired",
                                                "label": "Expired",
                                                "color": "error"
                                            }
                                        ]
                                    },
                                    {
                                        "id": "docStatus",
                                        "header": "Status",
                                        "accessorKey": "documentStatus",
                                        "type": "status",
                                        "width": "130px",
                                        "valueMapping": [
                                            {
                                                "value": "pending",
                                                "label": "Pending",
                                                "color": "warning"
                                            },
                                            {
                                                "value": "approved",
                                                "label": "Approved",
                                                "color": "success"
                                            },
                                            {
                                                "value": "rejected",
                                                "label": "Rejected",
                                                "color": "error"
                                            },
                                            {
                                                "value": "expired",
                                                "label": "Expired",
                                                "color": "error"
                                            }
                                        ]
                                    }
                                ],
                                "rowActions": [
                                    {
                                        "id": "view-doc",
                                        "label": "View",
                                        "icon": "Eye",
                                        "action": {
                                            "type": "open-modal",
                                            "target": "view-document"
                                        }
                                    },
                                    {
                                        "id": "download-doc",
                                        "label": "Download",
                                        "icon": "Download",
                                        "action": {
                                            "type": "api",
                                            "target": "download-doc-api"
                                        }
                                    }
                                ],
                                "pagination": {
                                    "enabled": true,
                                    "pageSize": 10
                                }
                            }
                        }
                    ]
                }
            ]
        }
    ]
}