{
    "id": "documents",
    "type": "tab-panel",
    "props": {
        "label": "Documents",
        "icon": "FileText"
    },
    "children": [
        {
            "id": "documents-stack",
            "type": "stack-layout",
            "props": {
                "spacing": "6"
            },
            "children": [
                {
                    "id": "docs-progress",
                    "type": "section-group",
                    "props": {
                        "title": "Document Requirements & Progress"
                    },
                    "children": [
                        {
                            "id": "docs-progress-links",
                            "type": "quick-links-widget",
                            "props": {
                                "layout": "grid",
                                "links": [
                                    {
                                        "id": "req-docs",
                                        "label": "Required Documents",
                                        "type": "card",
                                        "icon": "FileText",
                                        "description": "8 documents based on scheme type & UW method"
                                    },
                                    {
                                        "id": "submitted-docs",
                                        "label": "Submitted",
                                        "type": "card",
                                        "icon": "Upload",
                                        "description": "5 documents uploaded"
                                    },
                                    {
                                        "id": "missing-docs",
                                        "label": "Missing",
                                        "type": "card",
                                        "icon": "CircleAlert",
                                        "description": "3 documents - Requires immediate attention"
                                    },
                                    {
                                        "id": "verified-docs",
                                        "label": "Verified",
                                        "type": "card",
                                        "icon": "CircleCheck",
                                        "description": "3 documents approved for UW"
                                    },
                                    {
                                        "id": "expired-docs",
                                        "label": "Expired",
                                        "type": "card",
                                        "icon": "Clock",
                                        "description": "1 document needs resubmission"
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "id": "docs-alerts",
                    "type": "section-group",
                    "props": {
                        "title": "Document Intelligence & Blockers"
                    },
                    "children": [
                        {
                            "id": "docs-alerts-links",
                            "type": "quick-links-widget",
                            "props": {
                                "layout": "grid",
                                "links": [
                                    {
                                        "id": "alert-medical",
                                        "label": "BLOCKER: Medical Data Missing",
                                        "type": "card",
                                        "icon": "ShieldAlert",
                                        "description": "Medical examination reports required for members above 45 years.",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "request-document-form"
                                        }
                                    },
                                    {
                                        "id": "alert-kyc",
                                        "label": "KYC Documents Expired",
                                        "type": "card",
                                        "icon": "TriangleAlert",
                                        "description": "KYC documents expired on 2025-01-01.",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "request-document-form"
                                        }
                                    },
                                    {
                                        "id": "alert-fin",
                                        "label": "Financial Details Pending Verification",
                                        "type": "card",
                                        "icon": "Clock",
                                        "description": "Financial statements uploaded but awaiting underwriter verification.",
                                        "action": {
                                            "type": "open-sheet",
                                            "target": "verify-document-form"
                                        }
                                    }
                                ]
                            }
                        }
                    ]
                },
                {
                    "id": "docs-table-section",
                    "type": "section-group",
                    "props": {
                        "title": "Document Registry",
                        "actions": [
                            {
                                "id": "add-doc",
                                "label": "Add Document",
                                "icon": "Plus",
                                "variant": "default",
                                "action": {
                                    "type": "open-sheet",
                                    "target": "add-document-form"
                                }
                            }
                        ]
                    },
                    "children": [
                        {
                            "id": "documents-table",
                            "type": "data-table",
                            "props": {
                                "dataSource": {
                                    "type": "api",
                                    "api": {
                                        "endpoint": "/api/quotations/{{id}}/documents",
                                        "method": "GET"
                                    }
                                },
                                "selectable": true,
                                "columns": [
                                    {
                                        "id": "docType",
                                        "header": "Document Type",
                                        "accessorKey": "documentType",
                                        "type": "text",
                                        "width": "200px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "text"
                                    },
                                    {
                                        "id": "docSource",
                                        "header": "Source",
                                        "accessorKey": "documentSource",
                                        "type": "badge",
                                        "width": "120px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "select",
                                        "helpText": "Who submitted this document — Client, Broker, Lender, or Insurer",
                                        "valueMapping": [
                                            { "value": "client", "label": "Client", "color": "default" },
                                            { "value": "broker", "label": "Broker", "color": "info" },
                                            { "value": "lender", "label": "Lender", "color": "warning" },
                                            { "value": "insurer", "label": "Insurer", "color": "success" }
                                        ]
                                    },
                                    {
                                        "id": "linkedEntity",
                                        "header": "Linked To",
                                        "accessorKey": "linkedEntity",
                                        "type": "text",
                                        "width": "180px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "text"
                                    },
                                    {
                                        "id": "effDate",
                                        "header": "Effective Date",
                                        "accessorKey": "effectiveDate",
                                        "type": "date",
                                        "width": "140px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "text"
                                    },
                                    {
                                        "id": "expDate",
                                        "header": "Expiry Date",
                                        "accessorKey": "expiryDate",
                                        "type": "date",
                                        "width": "140px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "text",
                                        "helpText": "Date after which this document is no longer valid and must be resubmitted"
                                    },
                                    {
                                        "id": "uploadedBy",
                                        "header": "Uploaded By",
                                        "accessorKey": "uploadedBy",
                                        "type": "text",
                                        "width": "150px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "text"
                                    },
                                    {
                                        "id": "verStatus",
                                        "header": "Verification",
                                        "accessorKey": "verificationStatus",
                                        "type": "status",
                                        "width": "140px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "select",
                                        "helpText": "Underwriter verification status — Pending, Verified, Rejected, or Expired",
                                        "valueMapping": [
                                            { "value": "pending", "label": "Pending", "color": "warning" },
                                            { "value": "verified", "label": "Verified", "color": "success" },
                                            { "value": "rejected", "label": "Rejected", "color": "error" },
                                            { "value": "expired", "label": "Expired", "color": "error" }
                                        ]
                                    },
                                    {
                                        "id": "docStatus",
                                        "header": "Status",
                                        "accessorKey": "documentStatus",
                                        "type": "status",
                                        "width": "130px",
                                        "sortable": true,
                                        "filterable": true,
                                        "filterType": "select",
                                        "valueMapping": [
                                            { "value": "pending", "label": "Pending", "color": "warning" },
                                            { "value": "approved", "label": "Approved", "color": "success" },
                                            { "value": "rejected", "label": "Rejected", "color": "error" },
                                            { "value": "expired", "label": "Expired", "color": "error" }
                                        ]
                                    }
                                ],
                                "bulkActions": [
                                    {
                                        "id": "bulk-verify",
                                        "label": "Verify Selected",
                                        "icon": "CircleCheck",
                                        "variant": "outline"
                                    },
                                    {
                                        "id": "bulk-reject",
                                        "label": "Reject Selected",
                                        "icon": "CircleX",
                                        "variant": "destructive"
                                    }
                                ],
                                "rowActions": [
                                    {
                                        "id": "view-doc",
                                        "label": "View",
                                        "icon": "Eye",
                                        "action": {
                                            "type": "open-modal",
                                            "target": "view-document"
                                        }
                                    },
                                    {
                                        "id": "download-doc",
                                        "label": "Download",
                                        "icon": "Download",
                                        "action": {
                                            "type": "api-download",
                                            "target": "download-doc-api"
                                        }
                                    }
                                ],
                                "pagination": {
                                    "enabled": true,
                                    "pageSize": 10
                                }
                            }
                        }
                    ]
                }
            ]
        }
    ]
}