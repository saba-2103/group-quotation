{
    "id": "dashboard-page",
    "type": "stack-layout",
    "props": {
        "className": "p-6 gap-8"
    },
    "children": [
        {
            "id": "dashboard-header",
            "type": "page-header",
            "props": {
                "title": "Dashboard",
                "description": "Group PAS V1 — Quotation, Issuance, Policy Admin"
            }
        },
        {
            "id": "metrics-section",
            "type": "section-group",
            "props": {
                "title": "Key Metrics",
                "columns": 4
            },
            "children": [
                {
                    "id": "metric-pending-quotes",
                    "type": "metric-card",
                    "dataSource": {
                        "api": {
                            "endpoint": "/api/dashboard/metrics/pending-quotations",
                            "method": "GET"
                        }
                    },
                    "props": {
                        "label": "Pending Quotes",
                        "icon": "FileText",
                        "format": "number",
                        "priority": 1
                    }
                },
                {
                    "id": "metric-quotes-finalized",
                    "type": "metric-card",
                    "dataSource": {
                        "api": {
                            "endpoint": "/api/dashboard/metrics/new-business",
                            "method": "GET"
                        }
                    },
                    "props": {
                        "label": "Quotes Finalized",
                        "icon": "CheckCircle2",
                        "format": "number",
                        "priority": 1
                    }
                },
                {
                    "id": "metric-active-policies",
                    "type": "metric-card",
                    "dataSource": {
                        "api": {
                            "endpoint": "/api/dashboard/metrics/pending-alterations",
                            "method": "GET"
                        }
                    },
                    "props": {
                        "label": "Active Policies",
                        "icon": "ShieldCheck",
                        "format": "number",
                        "priority": 1
                    }
                },
                {
                    "id": "metric-members-in-flight",
                    "type": "metric-card",
                    "dataSource": {
                        "api": {
                            "endpoint": "/api/dashboard/metrics/renewals-due",
                            "method": "GET"
                        }
                    },
                    "props": {
                        "label": "Members in Flight",
                        "icon": "Users",
                        "format": "number",
                        "priority": 1
                    }
                }
            ]
        },
        {
            "id": "business-processes-section",
            "type": "section-group",
            "props": {
                "title": "Business Processes",
                "columns": 3
            },
            "children": [
                {
                    "id": "business-process-cards",
                    "type": "quick-links-widget",
                    "layout": {
                        "colSpan": 3
                    },
                    "props": {
                        "layout": "grid",
                        "links": [
                            {
                                "id": "quotation-card",
                                "label": "Quotation",
                                "type": "card",
                                "icon": "FileText",
                                "description": "Build and manage GTL quotes",
                                "action": {
                                    "type": "navigate",
                                    "target": "/quotation"
                                }
                            },
                            {
                                "id": "issuance-card",
                                "label": "Issuance",
                                "type": "card",
                                "icon": "ShieldCheck",
                                "description": "Process proposals into policies",
                                "action": {
                                    "type": "navigate",
                                    "target": "/issuance/proposals"
                                }
                            },
                            {
                                "id": "policy-admin-card",
                                "label": "Policy Admin",
                                "type": "card",
                                "icon": "Building2",
                                "description": "View clients, policies and members",
                                "action": {
                                    "type": "navigate",
                                    "target": "/policy-admin/policies"
                                }
                            }
                        ]
                    }
                }
            ]
        },
        {
            "id": "quick-actions-section",
            "type": "section-group",
            "props": {
                "title": "Quick Actions",
                "columns": 3
            },
            "children": [
                {
                    "id": "quick-action-buttons",
                    "type": "quick-links-widget",
                    "layout": {
                        "colSpan": 3
                    },
                    "props": {
                        "layout": "grid",
                        "links": [
                            {
                                "id": "new-quote-action",
                                "label": "New Quote",
                                "type": "link",
                                "icon": "Plus",
                                "action": {
                                    "type": "navigate",
                                    "target": "/quotation"
                                }
                            }
                        ]
                    }
                }
            ]
        }
    ]
}
