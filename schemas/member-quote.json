{
  "id": "member-quote-list-page",
  "type": "stack-layout",
  "props": { "className": "p-6 gap-6" },
  "children": [
    {
      "id": "member-quote-list-header",
      "type": "page-header",
      "props": {
        "title": "GCL — Member Quotes",
        "description": "Per-member quotes for Group Credit Life (one MemberQuote per loan disbursement). Hangs off a Policy, not a Quote — that's the GCL workflow shape."
      }
    },
    {
      "id": "member-quote-filters",
      "type": "filter-bar",
      "props": {
        "stateKey": "member-quote-filters",
        "filters": [
          {
            "id": "status",
            "label": "Status",
            "type": "select",
            "options": [
              { "value": "DRAFT", "label": "Draft" },
              { "value": "SUBMITTED", "label": "Submitted" },
              { "value": "FINALIZED", "label": "Finalized" }
            ]
          }
        ]
      }
    },
    {
      "id": "member-quotes-table",
      "type": "data-table",
      "dataSource": {
        "api": {
          "endpoint": "/api/quotation/member-quotes",
          "method": "GET"
        },
        "stateDependencies": ["member-quote-filters"]
      },
      "props": {
        "title": "Member Quotes",
        "headerActions": [
          {
            "id": "new-member-quote-btn",
            "label": "New Member Quote",
            "icon": "Plus",
            "type": "open-modal",
            "target": "create-member-quote-form",
            "variant": "default"
          }
        ],
        "columns": [
          {
            "id": "id",
            "accessorKey": "id",
            "label": "Member Quote ID",
            "type": "link",
            "linkRoute": "/quotation/member-quotes/:id"
          },
          { "id": "name", "accessorKey": "name", "label": "Member", "type": "text" },
          { "id": "policyId", "accessorKey": "policyId", "label": "Policy", "type": "text" },
          { "id": "planNo", "accessorKey": "planNo", "label": "Plan", "type": "text" },
          { "id": "status", "accessorKey": "status", "label": "Status", "type": "state-badge", "entity": "memberQuote" },
          { "id": "sumAssured", "accessorKey": "sumAssured", "label": "Sum assured", "type": "currency", "currency": "INR" },
          { "id": "premium", "accessorKey": "annualPremiumAmount", "label": "Annual premium", "type": "currency", "currency": "INR" }
        ],
        "rowActions": [
          {
            "id": "view-mq-btn",
            "label": "View",
            "icon": "Eye",
            "type": "navigate",
            "target": "/quotation/member-quotes/:id"
          }
        ],
        "emptyState": {
          "title": "No member quotes yet",
          "description": "Click \"New Member Quote\" to create one against an existing GCL policy."
        }
      }
    }
  ]
}
