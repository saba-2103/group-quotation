{
  "id": "quote-detail-page",
  "type": "stack-layout",
  "props": { "className": "p-6 gap-6" },
  "children": [
    {
      "id": "quote-detail-header",
      "type": "page-header",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "backHref": "/quotation",
        "backLabel": "All quotes",
        "title": "Quote {{id}}",
        "titleTemplate": "Quote {quoteNumber|id}",
        "description": "State-aware quote detail. Available actions depend on the current state and your active role.",
        "actions": [
          {
            "id": "view-proposal",
            "label": "Open in Issuance",
            "icon": "ExternalLink",
            "type": "navigate",
            "target": "/issuance/proposals",
            "variant": "outline"
          }
        ]
      }
    },
    {
      "id": "quote-state-summary",
      "type": "key-value-grid",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "columns": 4,
        "fields": [
          {
            "id": "status",
            "label": "Status",
            "accessorKey": "status",
            "type": "badge",
            "valueMapping": [
              { "value": "DRAFT", "label": "Draft", "variant": "secondary" },
              { "value": "SUBMITTED", "label": "Submitted", "variant": "info" },
              { "value": "SENT_TO_CLIENT", "label": "Sent to client", "variant": "info" },
              { "value": "ACCEPTED", "label": "Accepted", "variant": "teal" },
              { "value": "FINALIZED", "label": "Finalized", "variant": "success" },
              { "value": "REJECTED", "label": "Rejected", "variant": "destructive" },
              { "value": "WITHDRAWN", "label": "Withdrawn", "variant": "grey" },
              { "value": "EXPIRED", "label": "Expired", "variant": "grey" }
            ]
          },
          { "id": "client", "label": "Client", "accessorKey": "clientName", "fallbackKey": "clientId" },
          { "id": "policyType", "label": "Policy type", "accessorKey": "policyType" },
          { "id": "headcount", "label": "Headcount", "accessorKey": "headcount" }
        ]
      }
    },
    {
      "id": "quote-actions",
      "type": "action-bar",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": {
        "stateField": "status",
        "entityType": "quote",
        "entityId": "{{id}}",
        "stateActions": {
          "DRAFT": ["submit", "withdraw"],
          "SUBMITTED": ["send-to-client", "withdraw"],
          "SENT_TO_CLIENT": ["accept", "reject", "expire", "withdraw"],
          "ACCEPTED": ["finalize", "withdraw"],
          "FINALIZED": [],
          "REJECTED": [],
          "WITHDRAWN": [],
          "EXPIRED": []
        },
        "roleActions": {
          "sales": ["submit", "send-to-client", "expire", "finalize", "withdraw"],
          "partner_agent": [],
          "mph": ["accept", "reject"],
          "member": [],
          "uw": [],
          "ops": []
        },
        "actions": [
          {
            "id": "submit",
            "label": "Submit quote",
            "icon": "Send",
            "type": "api-mutation",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/submit", "method": "POST" },
            "successMessage": "Quote submitted"
          },
          {
            "id": "send-to-client",
            "label": "Send to client",
            "icon": "Mail",
            "type": "api-mutation",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/send-to-client", "method": "POST" }
          },
          {
            "id": "accept",
            "label": "Mark accepted",
            "icon": "ThumbsUp",
            "type": "api-mutation",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/accept", "method": "POST" }
          },
          {
            "id": "reject",
            "label": "Reject",
            "icon": "ThumbsDown",
            "type": "api-mutation",
            "variant": "destructive",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/reject", "method": "POST" }
          },
          {
            "id": "finalize",
            "label": "Finalize",
            "icon": "Lock",
            "type": "api-mutation",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/finalize", "method": "POST" },
            "successMessage": "Quote finalized; Proposal created in Issuance."
          },
          {
            "id": "withdraw",
            "label": "Withdraw",
            "icon": "Ban",
            "type": "api-mutation",
            "variant": "destructive",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/withdraw", "method": "POST" },
            "confirm": {
              "title": "Withdraw quote",
              "message": "Withdrawal is terminal. Continue?"
            }
          },
          {
            "id": "expire",
            "label": "Mark expired",
            "icon": "Clock",
            "type": "api-mutation",
            "variant": "outline",
            "refreshKey": "/api/quotation/quotes/{{id}}",
            "api": { "endpoint": "/api/quotation/quotes/{{id}}/expire", "method": "POST" },
            "confirm": {
              "title": "Mark quote expired",
              "message": "Use when the client did not respond within the validity window. Continue?"
            }
          }
        ]
      }
    },
    {
      "id": "quote-detail-tabs",
      "type": "tabs-container",
      "dataSource": {
        "api": { "endpoint": "/api/quotation/quotes/{{id}}", "method": "GET" }
      },
      "props": { "defaultValue": "key-data" },
      "children": [
        { "$ref": "schemas/tabs/quote/key-data.json" },
        { "$ref": "schemas/tabs/quote/plans.json" },
        { "$ref": "schemas/tabs/quote/census.json" },
        { "$ref": "schemas/tabs/quote/member-mapping.json" },
        { "$ref": "schemas/tabs/quote/pricing.json" },
        { "$ref": "schemas/tabs/quote/member-quotes-placeholder.json" }
      ]
    }
  ]
}
